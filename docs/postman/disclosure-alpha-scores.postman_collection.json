{
  "info": {
    "name": "Disclosure Alpha — Scores",
    "description": "Deterministic matrix scores, tier presets, and composite Pro 402 stub.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "ticker", "value": "AAPL" },
    { "key": "fiscalYear", "value": "2025" }
  ],
  "item": [
    {
      "name": "Deterministic matrix",
      "item": [
        {
          "name": "Full matrix (default)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/company/{{ticker}}/disclosure-matrix?fiscal_year={{fiscalYear}}&view=deterministic",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "company", "{{ticker}}", "disclosure-matrix"],
              "query": [
                { "key": "fiscal_year", "value": "{{fiscalYear}}" },
                { "key": "view", "value": "deterministic" }
              ]
            }
          }
        },
        {
          "name": "Tier lite (overall only)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/company/{{ticker}}/disclosure-matrix?fiscal_year={{fiscalYear}}&tier=lite",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "company", "{{ticker}}", "disclosure-matrix"],
              "query": [
                { "key": "fiscal_year", "value": "{{fiscalYear}}" },
                { "key": "tier", "value": "lite" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Pro stub (402)",
      "item": [
        {
          "name": "Composite view — expect 402",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/company/{{ticker}}/disclosure-matrix?fiscal_year={{fiscalYear}}&view=composite",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "company", "{{ticker}}", "disclosure-matrix"],
              "query": [
                { "key": "fiscal_year", "value": "{{fiscalYear}}" },
                { "key": "view", "value": "composite" }
              ]
            }
          },
          "response": [
            {
              "name": "402 Pro required",
              "status": "Payment Required",
              "code": 402,
              "body": "{\n  \"detail\": {\n    \"detail\": \"view=composite requires Disclosure Alpha Pro\",\n    \"available_views\": [\"deterministic\"],\n    \"pro_required\": true,\n    \"scoring_model_version\": \"deterministic_scoring_v3\"\n  }\n}"
            }
          ]
        }
      ]
    }
  ]
}
