{
  "info": {
    "name": "Disclosure Alpha — Scores",
    "description": "Deterministic matrix scores and tier presets.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "ticker", "value": "AAPL" },
    { "key": "fiscalYear", "value": "2025" }
  ],
  "item": [
    {
      "name": "Deterministic matrix",
      "item": [
        {
          "name": "Full matrix (default)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/company/{{ticker}}/disclosure-matrix?fiscal_year={{fiscalYear}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "company", "{{ticker}}", "disclosure-matrix"],
              "query": [
                { "key": "fiscal_year", "value": "{{fiscalYear}}" }
              ]
            }
          }
        },
        {
          "name": "Tier lite (overall only)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/company/{{ticker}}/disclosure-matrix?fiscal_year={{fiscalYear}}&tier=lite",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "company", "{{ticker}}", "disclosure-matrix"],
              "query": [
                { "key": "fiscal_year", "value": "{{fiscalYear}}" },
                { "key": "tier", "value": "lite" }
              ]
            }
          }
        }
      ]
    }
  ]
}
